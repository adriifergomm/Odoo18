<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- VISTA LISTA -->
    <record id="estate_property_view_list" model="ir.ui.view">
        <field name="name">estate.property.list</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <list string="Propiedades"
                  decoration-success="state in ('offer_received', 'offer_accepted')"
                  decoration-muted="state == 'sold'"
                  decoration-bf="state == 'offer_accepted'">
                <field name="name" string="Referencia"/>
                <field name="property_type_id" string="Tipo"/>
                <field name="city" string="Ciudad"/>
                <field name="tag_ids" string="Etiquetas" widget="many2many_tags" options="{'color_field': 'color'}"/>
                <field name="bedrooms" string="Hab."/>
                <field name="living_area" string="m²"/>
                <field name="expected_price" string="Precio Esperado"/>
                <field name="best_offer" string="Mejor Oferta"/>
                <field name="selling_price" string="Precio Venta"/>
                <field name="date_availability" string="Disponible" optional="hide"/>
                <field name="state" string="Estado"/>
            </list>
        </field>
    </record>

    <!-- VISTA KANBAN -->
    <record id="estate_property_view_kanban" model="ir.ui.view">
        <field name="name">estate.property.kanban</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <kanban default_group_by="property_type_id" records_draggable="false">
                <field name="name"/>
                <field name="expected_price"/>
                <field name="best_offer"/>
                <field name="selling_price"/>
                <field name="state"/>
                <field name="tag_ids"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                            </div>
                            <div>
                                <span>Precio esperado: </span>
                                <field name="expected_price" widget="monetary"/>
                            </div>
                            <div t-if="record.best_offer.raw_value">
                                <span>Mejor oferta: </span>
                                <field name="best_offer" widget="monetary"/>
                            </div>
                            <div t-if="record.selling_price.raw_value">
                                <span>Precio venta: </span>
                                <field name="selling_price" widget="monetary"/>
                            </div>
                            <div class="o_kanban_record_bottom mt4">
                                <field name="state" widget="badge"
                                    decoration-success="state in ('offer_received', 'offer_accepted')"
                                    decoration-danger="state == 'cancelled'"
                                    decoration-muted="state == 'sold'"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- VISTA FORMULARIO -->
    <record id="estate_property_view_form" model="ir.ui.view">
        <field name="name">estate.property.form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <form string="Propiedad">
                <header>
                    <button name="action_sold" string="Marcar como Vendida"
                            type="object" class="btn-primary"
                            invisible="state in ('sold', 'cancelled')"/>
                    <button name="action_cancel" string="Cancelar"
                            type="object"
                            invisible="state in ('sold', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="new,offer_received,offer_accepted,sold"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                                name="action_sold" icon="fa-home"
                                invisible="True">
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Referencia de la propiedad"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Clasificacion">
                            <field name="property_type_id"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                        </group>
                        <group string="Precios">
                            <field name="expected_price" widget="monetary"/>
                            <field name="best_offer" widget="monetary"/>
                            <field name="selling_price" widget="monetary"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Descripcion">
                            <group>
                                <group string="Caracteristicas">
                                    <field name="living_area"/>
                                    <field name="bedrooms"/>
                                    <field name="bathrooms"/>
                                    <field name="facades"/>
                                    <field name="garage"/>
                                    <field name="elevator"/>
                                </group>
                                <group string="Jardin">
                                    <field name="garden"/>
                                    <field name="garden_area" invisible="not garden"/>
                                    <field name="garden_orientation" invisible="not garden"/>
                                </group>
                            </group>
                            <field name="description" placeholder="Descripcion de la propiedad..."/>
                        </page>

                        <page string="Ubicacion">
                            <group>
                                <field name="street"/>
                                <field name="city"/>
                                <field name="zip_code"/>
                                <field name="province"/>
                            </group>
                        </page>

                        <page string="Ofertas">
                            <field name="offer_ids">
                                <list string="Ofertas"
                                      decoration-success="status == 'accepted'"
                                      decoration-danger="status == 'refused'">
                                    <field name="price" string="Precio"/>
                                    <field name="partner_id" string="Comprador"/>
                                    <field name="validity" string="Validez (dias)"/>
                                    <field name="date_deadline" string="Fecha Limite"/>
                                    <field name="status" string="Estado"/>
                                    <button name="action_accept" type="object"
                                            icon="fa-check" title="Aceptar"
                                            invisible="status != False"/>
                                    <button name="action_refuse" type="object"
                                            icon="fa-times" title="Rechazar"
                                            invisible="status != False"/>
                                </list>
                            </field>
                        </page>

                        <page string="Informacion adicional">
                            <group>
                                <field name="salesperson_id"/>
                                <field name="buyer_id"/>
                                <field name="owner_id"/>
                                <field name="date_availability"/>
                                <field name="total_area"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- BUSCADOR -->
    <record id="estate_property_view_search" model="ir.ui.view">
        <field name="name">estate.property.search</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <search string="Buscar Propiedades">
                <field name="name" string="Referencia"/>
                <field name="city" string="Ciudad"/>
                <field name="property_type_id" string="Tipo"/>
                <field name="tag_ids" string="Etiquetas"/>
                <filter string="Disponibles" name="available"
                        domain="[('state', 'in', ('new', 'offer_received'))]"/>
                <filter string="Con Oferta Aceptada" name="offer_accepted"
                        domain="[('state', '=', 'offer_accepted')]"/>
                <filter string="Vendidas" name="sold"
                        domain="[('state', '=', 'sold')]"/>
                <separator/>
                <filter string="Mis Propiedades" name="mine"
                        domain="[('salesperson_id', '=', uid)]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Tipo" name="group_type"
                            context="{'group_by': 'property_type_id'}"/>
                    <filter string="Estado" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Ciudad" name="group_city"
                            context="{'group_by': 'city'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACCION -->
    <record id="estate_property_action" model="ir.actions.act_window">
        <field name="name">Propiedades</field>
        <field name="res_model">estate.property</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_available': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea tu primera propiedad
            </p>
            <p>
                Añade propiedades para gestionar tus inmuebles.
            </p>
        </field>
    </record>

</odoo>
