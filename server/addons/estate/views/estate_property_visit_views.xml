<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LISTA -->
    <record id="estate_property_visit_view_list" model="ir.ui.view">
        <field name="name">estate.property.visit.list</field>
        <field name="model">estate.property.visit</field>
        <field name="arch" type="xml">
            <list string="Visitas"
                  decoration-success="result == 'offer_made'"
                  decoration-warning="result == 'interested'"
                  decoration-muted="result == 'not_interested'">
                <field name="date" string="Fecha y Hora"/>
                <field name="property_id" string="Propiedad"/>
                <field name="property_type_id" string="Tipo" optional="show"/>
                <field name="city" string="Ciudad" optional="show"/>
                <field name="partner_id" string="Cliente"/>
                <field name="agent_id" string="Agente" widget="many2one_avatar_user"/>
                <field name="duration" string="Duracion (h)" optional="hide"/>
                <field name="result" string="Resultado"/>
                <field name="notes" string="Notas" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- FORMULARIO -->
    <record id="estate_property_visit_view_form" model="ir.ui.view">
        <field name="name">estate.property.visit.form</field>
        <field name="model">estate.property.visit</field>
        <field name="arch" type="xml">
            <form string="Visita">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Propiedad">
                            <field name="property_id" options="{'no_create': True}"/>
                            <field name="property_type_id" readonly="1"/>
                            <field name="city" readonly="1"/>
                            <field name="expected_price" readonly="1" widget="monetary"/>
                        </group>
                        <group string="Visita">
                            <field name="date"/>
                            <field name="duration"/>
                            <field name="agent_id"/>
                            <field name="partner_id"/>
                            <field name="result"/>
                        </group>
                    </group>
                    <group string="Observaciones">
                        <field name="notes" nolabel="1"
                               placeholder="Comentarios sobre la visita, impresiones del cliente..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- CALENDARIO -->
    <record id="estate_property_visit_view_calendar" model="ir.ui.view">
        <field name="name">estate.property.visit.calendar</field>
        <field name="model">estate.property.visit</field>
        <field name="arch" type="xml">
            <calendar string="Agenda de Visitas"
                      date_start="date"
                      color="agent_id"
                      mode="month"
                      quick_create="false">
                <field name="property_id"/>
                <field name="partner_id"/>
                <field name="agent_id"/>
                <field name="result"/>
            </calendar>
        </field>
    </record>

    <!-- BUSQUEDA -->
    <record id="estate_property_visit_view_search" model="ir.ui.view">
        <field name="name">estate.property.visit.search</field>
        <field name="model">estate.property.visit</field>
        <field name="arch" type="xml">
            <search string="Buscar Visitas">
                <field name="property_id" string="Propiedad"/>
                <field name="partner_id" string="Cliente"/>
                <field name="agent_id" string="Agente"/>
                <field name="city" string="Ciudad"/>

                <filter string="Pendientes" name="pending"
                        domain="[('result', '=', 'pending')]"/>
                <filter string="Interesados" name="interested"
                        domain="[('result', '=', 'interested')]"/>
                <filter string="Han Hecho Oferta" name="offer_made"
                        domain="[('result', '=', 'offer_made')]"/>
                <separator/>
                <filter string="Mis Visitas" name="mine"
                        domain="[('agent_id', '=', uid)]"/>
                <filter string="Hoy" name="today"
                        domain="[('date', '&gt;=', datetime.datetime.now().strftime('%Y-%m-%d 00:00:00')),
                                  ('date', '&lt;=', datetime.datetime.now().strftime('%Y-%m-%d 23:59:59'))]"/>

                <group expand="0" string="Agrupar por">
                    <filter string="Propiedad" name="group_property"
                            context="{'group_by': 'property_id'}"/>
                    <filter string="Agente" name="group_agent"
                            context="{'group_by': 'agent_id'}"/>
                    <filter string="Resultado" name="group_result"
                            context="{'group_by': 'result'}"/>
                    <filter string="Ciudad" name="group_city"
                            context="{'group_by': 'city'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACCION GLOBAL DE VISITAS -->
    <record id="estate_property_visit_action" model="ir.actions.act_window">
        <field name="name">Visitas</field>
        <field name="res_model">estate.property.visit</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="context">{'search_default_mine': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay visitas programadas
            </p>
            <p>
                Registra las visitas de clientes a tus propiedades.
            </p>
        </field>
    </record>

</odoo>
