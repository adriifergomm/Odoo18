<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="estate_property_offer_view_list" model="ir.ui.view">
        <field name="name">estate.property.offer.list</field>
        <field name="model">estate.property.offer</field>
        <field name="arch" type="xml">
            <list string="Ofertas"
                  decoration-success="status == 'accepted'"
                  decoration-danger="status == 'refused'">
                <field name="price" string="Precio Ofertado"/>
                <field name="partner_id" string="Comprador"/>
                <field name="validity" string="Validez (dias)"/>
                <field name="date_deadline" string="Fecha Limite"/>
                <field name="status" string="Estado"/>
                <button name="action_accept" type="object" icon="fa-check" title="Aceptar"
                        invisible="status != False"/>
                <button name="action_refuse" type="object" icon="fa-times" title="Rechazar"
                        invisible="status != False"/>
            </list>
        </field>
    </record>

    <record id="estate_property_offer_action" model="ir.actions.act_window">
        <field name="name">Ofertas</field>
        <field name="res_model">estate.property.offer</field>
        <field name="view_mode">list</field>
        <field name="context">{}</field>
    </record>

</odoo>
