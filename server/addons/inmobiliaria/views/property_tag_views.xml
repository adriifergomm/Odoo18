<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST (inline editable) -->
    <record id="inmo_property_tag_view_list" model="ir.ui.view">
        <field name="name">inmo.property.tag.list</field>
        <field name="model">inmo.property.tag</field>
        <field name="arch" type="xml">
            <list string="Etiquetas" editable="top">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <!-- ACTION -->
    <record id="inmo_property_tag_action" model="ir.actions.act_window">
        <field name="name">Etiquetas</field>
        <field name="res_model">inmo.property.tag</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
