<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST -->
    <record id="inmo_property_visit_view_list" model="ir.ui.view">
        <field name="name">inmo.property.visit.list</field>
        <field name="model">inmo.property.visit</field>
        <field name="arch" type="xml">
            <list string="Visitas" decoration-muted="result == 'not_interested'">
                <field name="date" string="Fecha y Hora"/>
                <field name="property_id" string="Inmueble"/>
                <field name="partner_id" string="Cliente"/>
                <field name="agent_id" string="Agente"/>
                <field name="duration" string="Duracion (h)"/>
                <field name="result" string="Resultado"/>
            </list>
        </field>
    </record>

    <!-- FORM -->
    <record id="inmo_property_visit_view_form" model="ir.ui.view">
        <field name="name">inmo.property.visit.form</field>
        <field name="model">inmo.property.visit</field>
        <field name="arch" type="xml">
            <form string="Visita">
                <header>
                    <field name="result" widget="statusbar"
                           statusbar_visible="pending,interested,offer_made"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Datos Principales">
                            <field name="property_id"/>
                            <field name="partner_id"/>
                            <field name="agent_id"/>
                        </group>
                        <group string="Planificacion">
                            <field name="date"/>
                            <field name="duration"/>
                            <field name="result"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Observaciones">
                            <field name="notes" placeholder="Notas de la visita..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- CALENDAR -->
    <record id="inmo_property_visit_view_calendar" model="ir.ui.view">
        <field name="name">inmo.property.visit.calendar</field>
        <field name="model">inmo.property.visit</field>
        <field name="arch" type="xml">
            <calendar string="Visitas" date_start="date" color="agent_id"
                      event_limit="5" mode="month">
                <field name="property_id"/>
                <field name="partner_id"/>
                <field name="result"/>
            </calendar>
        </field>
    </record>

    <!-- SEARCH -->
    <record id="inmo_property_visit_view_search" model="ir.ui.view">
        <field name="name">inmo.property.visit.search</field>
        <field name="model">inmo.property.visit</field>
        <field name="arch" type="xml">
            <search string="Buscar Visitas">
                <field name="property_id"/>
                <field name="partner_id"/>
                <field name="agent_id"/>
                <separator/>
                <filter string="Pendientes" name="pending"
                        domain="[('result', '=', 'pending')]"/>
                <filter string="Interesados" name="interested"
                        domain="[('result', '=', 'interested')]"/>
                <filter string="Con Oferta" name="offer_made"
                        domain="[('result', '=', 'offer_made')]"/>
                <separator/>
                <filter string="Esta Semana" name="this_week"
                        domain="[('date', '>=', (context_today() + relativedelta(weeks=-1)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Inmueble" name="group_property"
                            context="{'group_by': 'property_id'}"/>
                    <filter string="Agente" name="group_agent"
                            context="{'group_by': 'agent_id'}"/>
                    <filter string="Resultado" name="group_result"
                            context="{'group_by': 'result'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="inmo_property_visit_action" model="ir.actions.act_window">
        <field name="name">Visitas</field>
        <field name="res_model">inmo.property.visit</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="context">{'search_default_pending': 1}</field>
    </record>

</odoo>
