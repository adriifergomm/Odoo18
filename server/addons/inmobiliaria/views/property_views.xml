<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- KANBAN -->
    <record id="inmo_property_view_kanban" model="ir.ui.view">
        <field name="name">inmo.property.kanban</field>
        <field name="model">inmo.property</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="id"/>
                <field name="name"/>
                <field name="reference"/>
                <field name="state"/>
                <field name="expected_price"/>
                <field name="rental_price"/>
                <field name="listing_type"/>
                <field name="city"/>
                <field name="living_area"/>
                <field name="bedrooms"/>
                <field name="bathrooms"/>
                <field name="image_128"/>
                <field name="salesperson_id"/>
                <field name="best_offer"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_image_wrapper">
                            <img t-att-src="kanban_image('inmo.property', 'image_128', record.id.raw_value)"
                                 alt="Inmueble" class="o_kanban_image"/>
                        </div>
                        <div class="oe_kanban_details">
                            <strong class="o_kanban_record_title">
                                <field name="name"/>
                            </strong>
                            <div class="o_kanban_tags_section">
                                <span class="badge bg-secondary">
                                    <field name="reference"/>
                                </span>
                            </div>
                            <ul>
                                <li t-if="record.city.raw_value">
                                    <i class="fa fa-map-marker"/> <field name="city"/>
                                </li>
                                <li>
                                    <i class="fa fa-expand"/> <field name="living_area"/> m²
                                    &amp;nbsp;·&amp;nbsp;
                                    <i class="fa fa-bed"/> <field name="bedrooms"/>
                                    &amp;nbsp;·&amp;nbsp;
                                    <i class="fa fa-bath"/> <field name="bathrooms"/>
                                </li>
                                <li t-if="record.listing_type.raw_value == 'rent' or record.listing_type.raw_value == 'sale_rent'">
                                    Alquiler: <field name="rental_price"/> €/mes
                                </li>
                                <li t-if="record.listing_type.raw_value == 'sale' or record.listing_type.raw_value == 'sale_rent'">
                                    Venta: <field name="expected_price"/> €
                                </li>
                            </ul>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="salesperson_id" widget="many2one_avatar_user"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="state" widget="label_selection"
                                           options="{'classes': {'available': 'success', 'with_offer': 'warning', 'reserved': 'info', 'closed': 'default', 'cancelled': 'danger'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- LIST -->
    <record id="inmo_property_view_list" model="ir.ui.view">
        <field name="name">inmo.property.list</field>
        <field name="model">inmo.property</field>
        <field name="arch" type="xml">
            <list string="Inmuebles"
                  decoration-success="state == 'available'"
                  decoration-warning="state == 'with_offer'"
                  decoration-info="state == 'reserved'"
                  decoration-muted="state == 'cancelled'">
                <field name="reference" optional="show"/>
                <field name="name"/>
                <field name="property_type_id" optional="show"/>
                <field name="listing_type"/>
                <field name="city" optional="show"/>
                <field name="living_area" optional="show"/>
                <field name="bedrooms" optional="show"/>
                <field name="expected_price"/>
                <field name="best_offer" optional="show"/>
                <field name="rental_price" optional="show"/>
                <field name="date_availability" optional="hide"/>
                <field name="salesperson_id" optional="show" widget="many2one_avatar_user"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'available'"
                       decoration-warning="state == 'with_offer'"
                       decoration-info="state == 'reserved'"
                       decoration-muted="state in ('closed', 'cancelled')"/>
            </list>
        </field>
    </record>

    <!-- FORM -->
    <record id="inmo_property_view_form" model="ir.ui.view">
        <field name="name">inmo.property.form</field>
        <field name="model">inmo.property</field>
        <field name="arch" type="xml">
            <form string="Inmueble">
                <header>
                    <button name="action_republish" type="object" string="Disponible"
                            class="btn-primary"
                            attrs="{'invisible': [('state', 'not in', ['closed', 'cancelled', 'reserved'])]}"/>
                    <button name="action_close" type="object" string="Cerrar Operacion"
                            class="btn-success"
                            attrs="{'invisible': [('state', 'not in', ['reserved'])]}"/>
                    <button name="action_cancel" type="object" string="Retirar"
                            class="btn-secondary"
                            attrs="{'invisible': [('state', 'in', ['closed', 'cancelled'])]}"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="available,with_offer,reserved,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_view_offers"
                                class="oe_stat_button" icon="fa-handshake-o">
                            <field string="Ofertas" name="offer_count" widget="statinfo"/>
                        </button>
                        <button type="object" name="action_view_visits"
                                class="oe_stat_button" icon="fa-calendar">
                            <field string="Visitas" name="visit_count" widget="statinfo"/>
                        </button>
                    </div>

                    <field name="image" widget="image" class="oe_avatar"
                           options="{'size': [350, 200]}"/>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Titulo del anuncio..."/>
                        </h1>
                        <div>
                            <field name="tag_ids" widget="many2many_tags"
                                   options="{'color_field': 'color'}"/>
                        </div>
                    </div>

                    <group>
                        <group string="Clasificacion">
                            <field name="reference"/>
                            <field name="property_type_id"/>
                            <field name="listing_type"/>
                            <field name="condition"/>
                            <field name="energy_rating"/>
                        </group>
                        <group string="Agencia">
                            <field name="salesperson_id"/>
                            <field name="owner_id"/>
                            <field name="buyer_id"/>
                            <field name="date_availability"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- TAB 1: Descripcion y ubicacion -->
                        <page string="Descripcion y Ubicacion" name="location">
                            <group>
                                <group string="Ubicacion">
                                    <field name="street"/>
                                    <field name="city"/>
                                    <field name="province"/>
                                    <field name="zip_code"/>
                                </group>
                                <group string="Caracteristicas Principales">
                                    <field name="living_area"/>
                                    <field name="usable_area"/>
                                    <field name="total_area"/>
                                    <field name="floor"/>
                                    <field name="facades"/>
                                    <field name="year_built"/>
                                    <field name="bedrooms"/>
                                    <field name="bathrooms"/>
                                </group>
                            </group>
                        </page>

                        <!-- TAB 2: Extras y equipamiento -->
                        <page string="Extras" name="extras">
                            <group>
                                <group string="Interiores">
                                    <field name="air_conditioning"/>
                                    <field name="heating"/>
                                    <field name="elevator"/>
                                    <field name="storage_room"/>
                                </group>
                                <group string="Exteriores">
                                    <field name="terrace"/>
                                    <field name="garden"/>
                                    <field name="garden_area"
                                           attrs="{'invisible': [('garden', '=', False)]}"/>
                                    <field name="garden_orientation"
                                           attrs="{'invisible': [('garden', '=', False)]}"/>
                                    <field name="pool"/>
                                </group>
                            </group>
                            <group>
                                <group string="Aparcamiento">
                                    <field name="garage"/>
                                    <field name="parking_spaces"
                                           attrs="{'invisible': [('garage', '=', False)]}"/>
                                </group>
                            </group>
                        </page>

                        <!-- TAB 3: Precios y financiero -->
                        <page string="Precios" name="prices">
                            <group>
                                <group string="Venta"
                                       attrs="{'invisible': [('listing_type', '=', 'rent')]}">
                                    <field name="expected_price"/>
                                    <field name="selling_price"/>
                                    <field name="best_offer"/>
                                    <field name="price_per_sqm"/>
                                </group>
                                <group string="Alquiler"
                                       attrs="{'invisible': [('listing_type', '=', 'sale')]}">
                                    <field name="rental_price"/>
                                    <field name="deposit"/>
                                </group>
                            </group>
                            <group>
                                <group string="Gastos y Comision">
                                    <field name="ibi"/>
                                    <field name="community_fee"/>
                                    <field name="commission"/>
                                    <field name="commission_amount"/>
                                </group>
                            </group>
                        </page>

                        <!-- TAB 4: Ofertas -->
                        <page string="Ofertas" name="offers">
                            <field name="offer_ids">
                                <list string="Ofertas"
                                      decoration-success="status == 'accepted'"
                                      decoration-danger="status == 'refused'">
                                    <field name="partner_id" string="Comprador"/>
                                    <field name="price" string="Precio Ofertado"/>
                                    <field name="validity" string="Validez (dias)"/>
                                    <field name="date_deadline" string="Caduca el"/>
                                    <field name="status" string="Estado"/>
                                    <button name="action_accept" type="object"
                                            string="Aceptar" icon="fa-check"
                                            attrs="{'invisible': [('status', '!=', False)]}"/>
                                    <button name="action_refuse" type="object"
                                            string="Rechazar" icon="fa-times"
                                            attrs="{'invisible': [('status', '!=', False)]}"/>
                                </list>
                            </field>
                        </page>

                        <!-- TAB 5: Visitas -->
                        <page string="Visitas" name="visits">
                            <field name="visit_ids">
                                <list string="Visitas">
                                    <field name="date" string="Fecha y Hora"/>
                                    <field name="partner_id" string="Cliente"/>
                                    <field name="agent_id" string="Agente"/>
                                    <field name="duration" string="Duracion (h)"/>
                                    <field name="result" string="Resultado"/>
                                    <field name="notes" string="Notas" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- SEARCH -->
    <record id="inmo_property_view_search" model="ir.ui.view">
        <field name="name">inmo.property.search</field>
        <field name="model">inmo.property</field>
        <field name="arch" type="xml">
            <search string="Buscar Inmuebles">
                <field name="name" string="Titulo / Ref."
                       filter_domain="['|', ('name', 'ilike', self), ('reference', 'ilike', self)]"/>
                <field name="city"/>
                <field name="property_type_id"/>
                <field name="salesperson_id"/>
                <field name="owner_id"/>
                <separator/>
                <filter string="Disponibles" name="available"
                        domain="[('state', '=', 'available')]"/>
                <filter string="Con Ofertas" name="with_offer"
                        domain="[('state', '=', 'with_offer')]"/>
                <filter string="Reservados" name="reserved"
                        domain="[('state', '=', 'reserved')]"/>
                <filter string="Cerrados" name="closed"
                        domain="[('state', '=', 'closed')]"/>
                <separator/>
                <filter string="Venta" name="sale"
                        domain="[('listing_type', 'in', ['sale', 'sale_rent'])]"/>
                <filter string="Alquiler" name="rent"
                        domain="[('listing_type', 'in', ['rent', 'sale_rent'])]"/>
                <separator/>
                <filter string="Mis Inmuebles" name="my_properties"
                        domain="[('salesperson_id', '=', uid)]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Tipo" name="group_type"
                            context="{'group_by': 'property_type_id'}"/>
                    <filter string="Estado" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Operacion" name="group_listing"
                            context="{'group_by': 'listing_type'}"/>
                    <filter string="Agente" name="group_salesperson"
                            context="{'group_by': 'salesperson_id'}"/>
                    <filter string="Ciudad" name="group_city"
                            context="{'group_by': 'city'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="inmo_property_action" model="ir.actions.act_window">
        <field name="name">Inmuebles</field>
        <field name="res_model">inmo.property</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_available': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea tu primer inmueble
            </p>
            <p>
                Gestiona el portfolio de propiedades de tu agencia inmobiliaria.
            </p>
        </field>
    </record>

</odoo>
