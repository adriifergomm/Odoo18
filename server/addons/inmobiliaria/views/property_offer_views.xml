<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST -->
    <record id="inmo_property_offer_view_list" model="ir.ui.view">
        <field name="name">inmo.property.offer.list</field>
        <field name="model">inmo.property.offer</field>
        <field name="arch" type="xml">
            <list string="Ofertas" decoration-success="status == 'accepted'"
                  decoration-danger="status == 'refused'">
                <field name="partner_id" string="Comprador"/>
                <field name="price" string="Precio Ofertado"/>
                <field name="validity" string="Validez (dias)"/>
                <field name="date_deadline" string="Caduca el"/>
                <field name="status" string="Estado"/>
                <button name="action_accept" type="object" string="Aceptar"
                        icon="fa-check" attrs="{'invisible': [('status', '!=', False)]}"/>
                <button name="action_refuse" type="object" string="Rechazar"
                        icon="fa-times" attrs="{'invisible': [('status', '!=', False)]}"/>
            </list>
        </field>
    </record>

    <!-- FORM -->
    <record id="inmo_property_offer_view_form" model="ir.ui.view">
        <field name="name">inmo.property.offer.form</field>
        <field name="model">inmo.property.offer</field>
        <field name="arch" type="xml">
            <form string="Oferta">
                <header>
                    <button name="action_accept" type="object" string="Aceptar Oferta"
                            class="btn-success"
                            attrs="{'invisible': [('status', '!=', False)]}"/>
                    <button name="action_refuse" type="object" string="Rechazar Oferta"
                            class="btn-danger"
                            attrs="{'invisible': [('status', '!=', False)]}"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="accepted,refused"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="price"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="validity"/>
                            <field name="date_deadline"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="inmo_property_offer_action" model="ir.actions.act_window">
        <field name="name">Ofertas</field>
        <field name="res_model">inmo.property.offer</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
